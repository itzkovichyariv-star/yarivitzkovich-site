---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatAuthors, formatStatus } from '../lib/publications';

const entries = await getCollection('publications');

const PUBLISHED = new Set(['published', 'in-press']);
const inProgress = entries
  .filter((e) => !PUBLISHED.has(e.data.status))
  .sort((a, b) => b.data.year - a.data.year);

const byStatus = new Map<string, typeof inProgress>();
for (const entry of inProgress) {
  const key = entry.data.status;
  if (!byStatus.has(key)) byStatus.set(key, []);
  byStatus.get(key)!.push(entry);
}

const statusOrder = ['under-review', 'pending-review', 'working-paper', 'draft'];
const groups = statusOrder
  .filter((s) => byStatus.has(s))
  .map((s) => ({ status: s, label: formatStatus(s as any) ?? s, items: byStatus.get(s)! }));
---
<BaseLayout title="Research in progress — Yariv Itzkovich" description="Work under review, in revision, or in draft.">
  <section class="max-w-4xl mx-auto px-6 md:px-10 pt-32 pb-12">
    <div class="font-mono text-xs uppercase tracking-widest text-soft mb-4">§ Ch. IV — Research</div>
    <h1
      class="font-display leading-[0.95] mb-6"
      style="font-size: clamp(3rem, 9vw, 7rem); font-weight: 300"
    >
      In&nbsp;progress.
    </h1>
    <p class="max-w-2xl text-lg text-muted font-display" style="font-weight: 300">
      Papers that are under review, in revision, or still working drafts. These are not listed among <a href="/publications" class="underline underline-offset-4 hover:opacity-70">published works</a>: the process hasn't yet decided what they will be.
    </p>
  </section>

  {inProgress.length === 0 ? (
    <section class="max-w-4xl mx-auto px-6 md:px-10 py-12 text-muted">
      <p>Nothing currently in progress that can be listed publicly.</p>
    </section>
  ) : (
    <section class="max-w-4xl mx-auto px-6 md:px-10 pb-32">
      {groups.map((group) => (
        <div class="mb-16">
          <div class="flex items-baseline gap-4 mb-6 pb-3 border-b" style="border-color: var(--divider)">
            <h2 class="font-display text-2xl md:text-3xl" style="font-weight: 400">{group.label}</h2>
            <span class="font-mono text-xs uppercase tracking-widest text-soft">
              {group.items.length} {group.items.length === 1 ? 'paper' : 'papers'}
            </span>
          </div>
          <ul class="space-y-8">
            {group.items.map((e) => (
              <li>
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <span class="font-mono text-[10px] uppercase tracking-widest text-soft">
                    {e.data.year}
                  </span>
                  {e.data.venue && (
                    <span class="font-mono text-[10px] uppercase tracking-widest text-soft">
                      · target: {e.data.venue}
                    </span>
                  )}
                </div>
                <h3 class="font-display text-xl md:text-2xl leading-snug mb-2" style="font-weight: 400">
                  {e.data.title}
                </h3>
                <p class="text-sm italic text-muted">{formatAuthors(e.data.authors)}</p>
                {e.data.tldr && (
                  <p class="mt-3 max-w-2xl text-sm text-muted leading-relaxed">{e.data.tldr}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  )}
</BaseLayout>
