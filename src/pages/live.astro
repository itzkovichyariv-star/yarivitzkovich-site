---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LiveGlobe from '../components/LiveGlobe.tsx';

// Build a sorted list of papers for the filter dropdown.
// We include 'published' and 'in-press' — anything readers can actually access.
const PUBLISHED = new Set(['published', 'in-press']);
const allPubs = await getCollection('publications');
const papers = allPubs
  .filter((e) => PUBLISHED.has(e.data.status))
  .map((e) => ({ slug: e.data.slug, title: e.data.title }))
  .sort((a, b) => a.title.localeCompare(b.title));
---
<BaseLayout
  title="Live — Yariv Itzkovich"
  description="Live globe of where my work travels: visits and downloads in real time, country by country."
>
  <section class="max-w-6xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">§ Ch. ⊙</div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <h1 class="font-display text-4xl md:text-5xl mb-3" style="font-weight: 300">Live.</h1>
        <p class="text-muted max-w-lg">
          Where my work travels. Each pin is a visit or a download — first-time readers in pink, returning readers in rose, and downloaders in deep maroon.
        </p>
        <p class="font-mono text-[11px] uppercase tracking-widest text-soft mt-3 max-w-lg">
          No cookies · no IP storage · geolocation in aggregate only
        </p>
      </div>
    </div>

    <LiveGlobe client:only="react" papers={papers} />

    <p class="mt-12 font-mono text-[10px] uppercase tracking-widest text-soft max-w-xl">
      Privacy: no cookies, no third-party tracking, no IP storage. Country / city geolocation is provided by Cloudflare on every request and used only in aggregate. Bot traffic is logged for audit but excluded from this view.
    </p>
  </section>

  <style is:global>
    /* Globe labels — positioned by globe.gl as DOM nodes; we style the editorial typography ourselves. */
    .gl-label {
      pointer-events: none;
      user-select: none;
      transform: translate(-50%, -50%);
      white-space: nowrap;
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text);
      transition: opacity 220ms ease-out;
      will-change: opacity;
    }
    .gl-label-continent {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.32em;
    }
    .gl-label-country {
      font-size: 9px;
      font-weight: 400;
      letter-spacing: 0.14em;
    }
  </style>
</BaseLayout>
