---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LiveGlobe from '../components/LiveGlobe.tsx';

// Build a sorted list of papers for the filter dropdown.
// We include 'published' and 'in-press' — anything readers can actually access.
const PUBLISHED = new Set(['published', 'in-press']);
const allPubs = await getCollection('publications');
const papers = allPubs
  .filter((e) => PUBLISHED.has(e.data.status))
  .map((e) => ({ slug: e.data.slug, title: e.data.title }))
  .sort((a, b) => a.title.localeCompare(b.title));
---
<BaseLayout
  title="Live — Yariv Itzkovich"
  description="Live globe of where my work travels: visits and downloads in real time, country by country."
>
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24">
    <div class="grid grid-cols-12 gap-6 mb-8 md:mb-12">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">§ Ch. ⊙</div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <h1 class="font-display text-4xl md:text-5xl mb-3" style="font-weight: 300">Live.</h1>
        <p class="text-muted max-w-lg">
          Where my work travels. Each pin is a visit or a download — first-time readers in pink, returning readers in rose, and downloaders in deep maroon.
        </p>
        <p class="font-mono text-[11px] uppercase tracking-widest text-soft mt-3 max-w-lg">
          No cookies · no IP storage · geolocation in aggregate only
        </p>
      </div>
    </div>

    <LiveGlobe client:only="react" papers={papers} />

    <p class="mt-12 font-mono text-[10px] uppercase tracking-widest text-soft max-w-xl">
      Privacy: no cookies, no third-party tracking, no IP storage. Country / city geolocation is provided by Cloudflare on every request and used only in aggregate. Bot traffic is logged for audit but excluded from this view.
    </p>
  </section>

  <style is:global>
    /* Globe labels — positioned by globe.gl as DOM nodes; we style the editorial typography ourselves. */
    .gl-label {
      pointer-events: none;
      user-select: none;
      transform: translate(-50%, -50%);
      white-space: nowrap;
      font-family: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      /* Crisp white text with a soft dark shadow so labels read against any
         part of the satellite texture (ocean, forest, desert, etc.) */
      color: #f4efe6;
      text-shadow:
        0 0 6px rgba(0, 0, 0, 0.85),
        0 0 12px rgba(0, 0, 0, 0.5);
      transition: opacity 220ms ease-out;
      will-change: opacity;
    }
    .gl-label-continent {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.32em;
    }
    .gl-label-country {
      font-size: 9px;
      font-weight: 400;
      letter-spacing: 0.14em;
    }
    .gl-label-country-active {
      /* Countries with actual download/visit activity: brighter, larger,
         tinted in the brand accent so they read as data, not chrome. */
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: #FFB347; /* warm gold — pops against blue ocean */
      text-shadow:
        0 0 8px rgba(255, 90, 30, 0.55),
        0 0 14px rgba(0, 0, 0, 0.85);
    }

    /* Pin-card entrance — slight rise + fade, like a 3D sign settling in */
    @keyframes pinCardIn {
      from {
        opacity: 0;
        transform: translateY(12px) scale(0.97);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
    .pin-card {
      transition: transform 200ms ease-out, box-shadow 200ms ease-out;
    }
    .pin-card:hover {
      transform: translateY(-2px);
      box-shadow:
        0 20px 52px rgba(0, 0, 0, 0.40),
        0 5px 14px rgba(0, 0, 0, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.26),
        inset 0 -1px 0 rgba(0, 0, 0, 0.18);
    }

    /* BreakdownDrawer entrance — owner-only details overlay */
    @keyframes breakdownFadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes breakdownPanelIn {
      from {
        opacity: 0;
        transform: translateY(20px) scale(0.985);
      }
      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
  </style>
</BaseLayout>
