---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationsBrowser from '../../components/publications/PublicationsBrowser';
import { TOPICS } from '../../data/topics';
import type { Publication } from '../../lib/publications';

const entries = await getCollection('publications');

const allPubs: Publication[] = entries
  .map((e) => ({
    id: e.data.id,
    slug: e.data.slug,
    title: e.data.title,
    authors: e.data.authors,
    year: e.data.year,
    type: e.data.type,
    status: e.data.status,
    venue: e.data.venue ?? null,
    venueShort: e.data.venueShort ?? null,
    volume: e.data.volume ?? null,
    issue: e.data.issue ?? null,
    pages: e.data.pages ?? null,
    doi: e.data.doi ?? null,
    url: e.data.url ?? null,
    topics: e.data.topics,
    methods: e.data.methods,
    featured: e.data.featured,
    tldr: e.data.tldr,
    abstract: e.data.abstract,
    pdf: e.data.pdf,
    podcast: e.data.podcast,
    bibtex: e.data.bibtex,
    image: e.data.image,
    isbn: e.data.isbn,
    publisher: e.data.publisher,
  }))
  .sort((a, b) => b.year - a.year);

// Only accepted publications go in the main index (published or in-press).
// Under-review / working-paper / pending-review / draft are shown on /research.
const PUBLISHED_STATUSES = new Set(['published', 'in-press']);
const publications = allPubs.filter((p) => PUBLISHED_STATUSES.has(p.status));
const inProgress = allPubs.filter((p) => !PUBLISHED_STATUSES.has(p.status));

// Only expose filter options that would actually return results.
const usedTopicIds = new Set<string>();
const usedTypes = new Set<string>();
for (const p of publications) {
  p.topics.forEach((t) => usedTopicIds.add(t));
  usedTypes.add(p.type);
}
const topicOptions = TOPICS.filter((t) => usedTopicIds.has(t.id)).map((t) => ({ id: t.id, label: t.label }));
const typeOptions = Array.from(usedTypes);
const totalPublications = publications.length;
const inProgressCount = inProgress.length;
---
<BaseLayout title={`Publications — Yariv Itzkovich`}>
  <section class="max-w-7xl mx-auto px-6 md:px-10 pt-32 pb-10">
    <div class="font-mono text-xs uppercase tracking-widest text-soft mb-4">§ Ch. III — Writing</div>
    <h1
      class="font-display leading-[0.95] mb-6"
      style="font-size: clamp(3rem, 9vw, 7rem); font-weight: 300"
    >
      Publications.
    </h1>
    <p class="max-w-2xl text-lg text-muted font-display" style="font-weight: 300">
      {totalPublications} published works across four domains, built up around the same stubborn question asked from different angles — <em>why do we let each other be treated badly at work, and what might we do about it?</em>
    </p>
    {inProgressCount > 0 && (
      <p class="max-w-2xl mt-6 text-sm text-muted">
        <span class="font-mono text-xs uppercase tracking-widest text-soft">Not yet published:</span>{' '}
        <a href="/research" class="underline underline-offset-4 hover:opacity-70">{inProgressCount} papers in progress</a> — under review, in revision, or working drafts.
      </p>
    )}
  </section>

  <PublicationsBrowser
    client:load
    publications={publications}
    topics={topicOptions}
    availableTypes={typeOptions}
  />
</BaseLayout>
