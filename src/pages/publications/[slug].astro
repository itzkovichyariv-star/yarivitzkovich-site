---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOPICS } from '../../data/topics';
import {
  formatAuthors,
  formatStatus,
  formatType,
  generateBibtex,
  type Publication,
} from '../../lib/publications';
import { generateAPA, generateMLA, generateChicago, stripMarkdownItalics } from '../../lib/citations';

export async function getStaticPaths() {
  const entries = await getCollection('publications');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pub: Publication = {
  id: entry.data.id,
  slug: entry.data.slug,
  title: entry.data.title,
  authors: entry.data.authors,
  year: entry.data.year,
  type: entry.data.type,
  status: entry.data.status,
  venue: entry.data.venue ?? null,
  venueShort: entry.data.venueShort ?? null,
  volume: entry.data.volume ?? null,
  issue: entry.data.issue ?? null,
  pages: entry.data.pages ?? null,
  doi: entry.data.doi ?? null,
  url: entry.data.url ?? null,
  topics: entry.data.topics,
  methods: entry.data.methods,
  featured: entry.data.featured,
  tldr: entry.data.tldr,
  abstract: entry.data.abstract,
  pdf: entry.data.pdf,
  podcast: entry.data.podcast,
  bibtex: entry.data.bibtex,
  image: entry.data.image,
  isbn: entry.data.isbn,
  publisher: entry.data.publisher,
};

const isBook = pub.type === 'book' || pub.type === 'edited-book';
const isPublished = pub.status === 'published' || pub.status === 'in-press';

const topicLabel = (id: string) => TOPICS.find((t) => t.id === id)?.label ?? id;
const statusLabel = formatStatus(pub.status);
const bibtex = generateBibtex(pub);
const apa = stripMarkdownItalics(generateAPA(pub));
const mla = stripMarkdownItalics(generateMLA(pub));
const chicago = stripMarkdownItalics(generateChicago(pub));

const citations = [
  { label: 'APA 7', text: apa },
  { label: 'MLA 9', text: mla },
  { label: 'Chicago', text: chicago },
  { label: 'BibTeX', text: bibtex },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: pub.title,
  datePublished: `${pub.year}-01-01`,
  author: pub.authors.map((a) => ({ '@type': 'Person', name: a.name })),
  publisher: pub.venue ? { '@type': 'Organization', name: pub.venue } : undefined,
  abstract: pub.abstract,
  url: new URL(`/publications/${pub.slug}`, Astro.site).href,
  identifier: pub.doi ? `https://doi.org/${pub.doi}` : undefined,
};
---
<BaseLayout title={`${pub.title} — Yariv Itzkovich`} description={pub.tldr ?? pub.abstract}>
  <article class="max-w-4xl mx-auto px-6 md:px-10 pt-32 pb-24" {...(!isPublished ? {'data-pagefind-ignore': ''} : {})}>
    <a href="/publications" class="font-mono text-xs uppercase tracking-widest text-soft hover:opacity-60 inline-flex items-center gap-2">
      <span>←</span> All publications
    </a>

    <div class="mt-10 flex items-center gap-2 flex-wrap">
      <span class="font-mono text-xs uppercase tracking-widest text-muted">
        {pub.year} · {formatType(pub.type)}
      </span>
      {statusLabel && (
        <span class="font-mono text-[10px] uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: var(--color-accent); color: var(--color-bg)">
          {statusLabel}
        </span>
      )}
    </div>

    {isBook && pub.image ? (
      <div class="mt-8 grid md:grid-cols-[180px_1fr] gap-8 items-start">
        <img src={pub.image} alt={`${pub.title} cover`} class="w-[180px] rounded-sm shadow-[0_8px_30px_rgba(26,22,18,0.18)]" loading="lazy" />
        <div>
          <h1 class="font-display text-3xl md:text-5xl leading-[1.05] mb-4" style="font-weight: 400">
            {pub.title}
          </h1>
          <p class="text-base italic text-muted mb-2">{formatAuthors(pub.authors)}</p>
          {pub.publisher && <p class="text-base text-muted mb-1">{pub.publisher}</p>}
          {pub.isbn && <p class="font-mono text-xs text-soft mb-4">ISBN {pub.isbn}</p>}
        </div>
      </div>
    ) : (
      <>
        <h1 class="font-display text-4xl md:text-6xl leading-[1.05] mt-6 mb-6" style="font-weight: 400">
          {pub.title}
        </h1>
        <p class="text-base italic text-muted mb-2">{formatAuthors(pub.authors)}</p>
        {pub.venue && <p class="text-base text-muted mb-10">{pub.venue}{pub.volume ? `, ${pub.volume}${pub.issue ? `(${pub.issue})` : ''}` : ''}{pub.pages ? `, ${pub.pages}` : ''}</p>}
      </>
    )}

    <div class="flex flex-wrap gap-1.5 mb-12">
      {pub.topics.map((t) => (
        <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full border" style="border-color: var(--divider)">
          {topicLabel(t)}
        </span>
      ))}
      {pub.methods.map((m) => (
        <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 rounded-full" style="background-color: rgba(26,22,18,0.08)">
          {m}
        </span>
      ))}
    </div>

    {pub.tldr && (
      <div class="mb-10 pl-5 border-l-2" style="border-color: var(--color-accent)">
        <div class="font-mono text-xs uppercase tracking-widest text-muted mb-2">TL;DR</div>
        <p class="font-display text-xl leading-snug" style="font-weight: 400">{pub.tldr}</p>
      </div>
    )}

    <div class="flex flex-wrap gap-3 mb-4">
      {pub.pdf?.available && pub.pdf.path && isPublished && (
        <a href={pub.pdf.path} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm border hover:opacity-70 transition-opacity" style="border-color: var(--divider)" download>
          PDF ↓
        </a>
      )}
      {pub.doi && (
        <a href={`https://doi.org/${pub.doi}`} class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm border hover:opacity-70 transition-opacity" style="border-color: var(--divider)" target="_blank" rel="noopener noreferrer">
          DOI ↗
        </a>
      )}
      {pub.abstract && (
        <button
          type="button"
          id="abstract-toggle"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-sm border hover:opacity-70 transition-all"
          style="border-color: var(--divider)"
          aria-expanded="false"
          aria-controls="abstract-panel"
        >
          Abstract
        </button>
      )}
    </div>

    {pub.abstract && (
      <div id="abstract-panel" class="mb-10 overflow-hidden" style="display:none">
        <p class="leading-relaxed pt-2 pb-6" style="opacity: 0.85">{pub.abstract}</p>
      </div>
    )}

    <script is:inline>
      (function () {
        var btn = document.getElementById('abstract-toggle');
        var panel = document.getElementById('abstract-panel');
        if (!btn || !panel) return;
        btn.addEventListener('click', function () {
          var open = panel.style.display !== 'none';
          panel.style.display = open ? 'none' : 'block';
          btn.setAttribute('aria-expanded', String(!open));
          btn.style.backgroundColor = open ? '' : 'var(--color-ink)';
          btn.style.color = open ? '' : 'var(--color-bg)';
          btn.style.borderColor = open ? 'var(--divider)' : 'var(--color-ink)';
        });
      })();
    </script>

    {pub.podcast?.available && pub.podcast.path && (
      <section class="mb-12">
        <div class="font-mono text-xs uppercase tracking-widest text-muted mb-3">Listen</div>
        {pub.podcast.description && (
          <p class="text-sm text-muted mb-3">{pub.podcast.description}</p>
        )}
        <audio controls class="w-full rounded-lg" style="accent-color: var(--color-accent)">
          <source src={pub.podcast.path} type="audio/mp4" />
          Your browser does not support the audio element.
        </audio>
      </section>
    )}

    <section class="mb-12" id="cite-section">
      <div class="font-mono text-xs uppercase tracking-widest text-muted mb-3">Cite</div>
      <div class="flex gap-1 flex-wrap mb-3" id="cite-tabs">
        {citations.map((c, i) => (
          <button
            type="button"
            data-cite-tab={i}
            class={`cite-tab font-mono text-[10px] uppercase tracking-widest px-3 py-1 rounded-full border transition-colors ${i === 0 ? 'active' : ''}`}
            style={i === 0 ? 'background-color: var(--color-ink); color: var(--color-bg); border-color: var(--color-ink)' : 'border-color: var(--divider)'}
          >
            {c.label}
          </button>
        ))}
      </div>
      {citations.map((c, i) => (
        <div data-cite-panel={i} class={`cite-panel ${i !== 0 ? 'hidden' : ''}`}>
          <pre class="font-mono text-xs p-4 rounded-lg overflow-x-auto whitespace-pre-wrap" style="background-color: rgba(26,22,18,0.06)">{c.text}</pre>
          <button
            type="button"
            data-copy-text={c.text}
            class="cite-copy font-mono text-[10px] uppercase tracking-widest text-muted mt-2 hover:opacity-60 transition-opacity"
          >
            Copy
          </button>
        </div>
      ))}
    </section>

    <script is:inline>
      (function () {
        var section = document.getElementById('cite-section');
        if (!section) return;
        var tabs = section.querySelectorAll('.cite-tab');
        var panels = section.querySelectorAll('.cite-panel');
        tabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            var idx = tab.getAttribute('data-cite-tab');
            tabs.forEach(function (t) {
              t.style.backgroundColor = '';
              t.style.color = '';
              t.style.borderColor = 'var(--divider)';
            });
            tab.style.backgroundColor = 'var(--color-ink)';
            tab.style.color = 'var(--color-bg)';
            tab.style.borderColor = 'var(--color-ink)';
            panels.forEach(function (p) { p.classList.add('hidden'); });
            var panel = section.querySelector('[data-cite-panel="' + idx + '"]');
            if (panel) panel.classList.remove('hidden');
          });
        });
        section.querySelectorAll('.cite-copy').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var text = btn.getAttribute('data-copy-text');
            if (!text) return;
            navigator.clipboard.writeText(text).then(function () {
              var orig = btn.textContent;
              btn.textContent = 'Copied!';
              setTimeout(function () { btn.textContent = orig; }, 1500);
            });
          });
        });
      })();
    </script>

    <section class="prose-custom max-w-none">
      <Content />
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>
