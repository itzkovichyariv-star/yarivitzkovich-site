---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { formatStatus, formatType } from '../lib/publications';

const allPubs = await getCollection('publications');
const PUBLISHED = new Set(['published', 'in-press']);
const published = allPubs.filter((e) => PUBLISHED.has(e.data.status));
const selected = published
  .filter((e) => e.data.featured)
  .sort((a, b) => b.data.year - a.data.year);
const totalPublications = published.length;

const fields = [
  {
    num: '01',
    title: 'Workplace incivility & its transmission',
    desc: 'How mistreatment travels through organizational hierarchies — from supervisors to subordinates, from witnesses to actors. Why one rude moment reshapes a team.',
    count: '14 works',
    href: '/publications?topics=incivility',
  },
  {
    num: '02',
    title: 'Bystander intervention & AI',
    desc: 'Can artificial intelligence act as a real-time witness to workplace harm? Testing AI-mediated interventions in organizational settings.',
    count: '6 works',
    href: '/publications?topics=bystander,ai',
  },
  {
    num: '03',
    title: 'Workplace bullying and its cascades',
    desc: 'How bullying moves through teams, higher education, and voluntary organizations — scoping reviews, tit-for-tat dynamics, and the witnesses who get pulled in alongside targets.',
    count: '6 works',
    href: '/publications?topics=bullying',
  },
];

const nowItems = [
  {
    label: 'Writing',
    title: 'AI as an Automated Bystander',
    note: 'Paper under review at HRMR. Can machines witness harm without replacing human courage?',
  },
  {
    label: 'Analysing',
    title: 'ADHD training program, T1–T4',
    note: 'Repeated-measures data on emotional intelligence, employability, and wellbeing.',
  },
  {
    label: 'Editing',
    title: 'Journal of Managerial Psychology',
    note: 'Handling manuscripts on dehumanisation, flexible HRM, and the shape of modern work.',
  },
];
const nowUpdated = 'April 2026';

---
<BaseLayout title={`${site.name} — Research on workplace mistreatment & AI`}>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-40 pb-32">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-2 pt-4">
        <div class="font-mono text-xs uppercase tracking-widest text-soft fade-up" style="animation-delay: 0.1s">
          № 001
        </div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <h1
          class="font-display leading-[0.95] tracking-tight fade-up"
          style="font-size: clamp(2.5rem, 8vw, 6.5rem); font-weight: 300; animation-delay: 0.2s"
        >
          {site.name}.
        </h1>
        <div class="mt-8 md:mt-12 grid grid-cols-12 gap-6">
          <div class="col-span-12 md:col-span-8">
            <p
              class="font-display leading-snug fade-up"
              style="font-size: clamp(1.35rem, 2.8vw, 2.1rem); animation-delay: 0.4s; font-weight: 300"
            >
              I study how <em class="text-accent not-italic" style="font-style: italic">mistreatment</em> moves through organizations — and whether machines can learn to interrupt it.
            </p>
            <p class="mt-8 text-base leading-relaxed text-muted max-w-xl fade-up" style="animation-delay: 0.6s">
              Associate Editor at the <em>Journal of Managerial Psychology</em>. Faculty in Human Resources Management & Organizational Development at Ariel University. Practitioner-scholar working at the seam between research on workplace harm and tools that might ease it.
            </p>
          </div>
          <div class="col-span-12 md:col-span-4 md:pt-4">
            {site.headshot && (
              <img
                src={site.headshot}
                alt={`${site.name} headshot`}
                class="w-20 h-20 rounded-full object-cover mb-5 fade-up"
                style="animation-delay: 0.65s; box-shadow: 0 4px 20px rgba(26,22,18,0.15)"
                width="80"
                height="80"
                loading="eager"
              />
            )}
            <div class="font-mono text-xs uppercase tracking-widest text-soft mb-3 fade-up" style="animation-delay: 0.7s">
              At present
            </div>
            <div class="space-y-2 text-sm fade-up" style="animation-delay: 0.8s">
              <div>{site.affiliation.en}</div>
              <div class="text-muted">{site.location.en}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="h-px border-divider" style="background-color: var(--divider)"></div>
  </div>

  <!-- Fields of inquiry -->
  <section id="work" class="max-w-6xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">§ Ch. I</div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <h2 class="font-display text-4xl md:text-5xl" style="font-weight: 300">Fields of inquiry.</h2>
      </div>
    </div>

    <div>
      {fields.map((field) => (
        <div class="grid grid-cols-12 gap-6 py-10 border-t" style="border-color: var(--divider)">
          <div class="col-span-12 md:col-span-2">
            <div class="font-mono text-sm text-muted">{field.num}</div>
          </div>
          <div class="col-span-12 md:col-span-7">
            <h3 class="font-display text-2xl md:text-3xl mb-3" style="font-weight: 400">{field.title}</h3>
            <p class="text-muted max-w-lg">{field.desc}</p>
          </div>
          <div class="col-span-12 md:col-span-3 md:text-right">
            <div class="font-mono text-xs uppercase tracking-widest text-soft mb-2">{field.count}</div>
            <a href={field.href} class="inline-flex items-center gap-1 text-sm group">
              <span class="border-b" style="border-color: currentColor">See papers</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" aria-hidden="true">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- NOW section -->
  <section id="now" style="background-color: var(--panel); color: var(--panel-text); border-top: 1px solid var(--panel-divider); border-bottom: 1px solid var(--panel-divider)">
    <div class="max-w-6xl mx-auto px-6 md:px-10 py-24 md:py-32 grain">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-2">
          <div class="font-mono text-xs uppercase tracking-widest" style="color: var(--panel-label)">§ Ch. II</div>
        </div>
        <div class="col-span-12 md:col-span-10">
          <h2 class="font-display text-4xl md:text-5xl mb-12" style="font-weight: 300">Now.</h2>
          <div class="grid md:grid-cols-3 gap-8">
            {nowItems.map((item) => (
              <div>
                <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--panel-label)">{item.label}</div>
                <p class="font-display text-xl leading-snug mb-2" style="font-weight: 400">{item.title}</p>
                <p class="text-sm" style="color: var(--panel-muted)">{item.note}</p>
              </div>
            ))}
          </div>
          <div class="mt-16 font-mono text-xs uppercase tracking-widest" style="color: var(--panel-label); opacity: 0.8">
            Last updated · {nowUpdated}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Selected Writing -->
  <section id="writing" class="max-w-6xl mx-auto px-6 md:px-10 py-24 md:py-32">
    <div class="grid grid-cols-12 gap-6 mb-12">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">§ Ch. III</div>
      </div>
      <div class="col-span-12 md:col-span-10 flex items-baseline justify-between flex-wrap gap-4">
        <h2 class="font-display text-4xl md:text-5xl" style="font-weight: 300">Selected writing.</h2>
        <a href="/publications" class="inline-flex items-center gap-1 text-sm group">
          <span class="border-b" style="border-color: currentColor">All {totalPublications} publications</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
          </svg>
        </a>
      </div>
    </div>

    <div
      id="selected-rotator"
      class="rotator"
      data-interval="15000"
      aria-live="polite"
    >
      {selected.map((entry, i) => {
        const statusLabel = formatStatus(entry.data.status);
        return (
          <a
            href={`/publications/${entry.data.slug}`}
            class={`pub-row rotator-item grid grid-cols-12 gap-6 py-8 border-t cursor-pointer${i === 0 ? ' is-visible' : ''}`}
            style="border-color: var(--divider)"
            data-index={i}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            <div class="col-span-3 md:col-span-2 font-mono text-sm text-muted">{entry.data.year}</div>
            <div class="col-span-9 md:col-span-8">
              <div class="flex items-center gap-3 mb-2 flex-wrap">
                <span class="font-mono text-xs uppercase tracking-widest text-soft">{formatType(entry.data.type)}</span>
                {statusLabel && (
                  <span class="font-mono text-xs uppercase tracking-widest px-2 py-0.5 rounded" style="background-color: var(--color-accent); color: var(--color-bg)">
                    {statusLabel}
                  </span>
                )}
              </div>
              <h3 class="pub-title font-display text-xl md:text-2xl leading-snug" style="font-weight: 400">{entry.data.title}</h3>
              <p class="text-sm text-muted mt-2 italic">{entry.data.venue}</p>
            </div>
            <div class="col-span-12 md:col-span-2 md:text-right">
              <svg class="pub-arrow ml-auto" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
              </svg>
            </div>
          </a>
        );
      })}
    </div>
    {selected.length > 1 && (
      <div id="selected-rotator-controls" class="mt-6 flex items-center gap-3">
        {selected.map((_, i) => (
          <button
            type="button"
            class={`rotator-dot ${i === 0 ? 'is-active' : ''}`}
            data-dot-index={i}
            aria-label={`Show featured work ${i + 1} of ${selected.length}`}
          />
        ))}
        <span
          class="ml-4 font-mono text-[11px] uppercase tracking-widest text-soft tabular-nums"
          id="selected-rotator-counter"
        >
          01 / {String(selected.length).padStart(2, '0')}
        </span>
      </div>
    )}
    <script is:inline define:vars={{ intervalMs: 15000 }}>
      (() => {
        const rotator = document.getElementById('selected-rotator');
        if (!rotator) return;
        const items = Array.from(rotator.querySelectorAll('.rotator-item'));
        if (items.length <= 1) return;
        const dots = Array.from(document.querySelectorAll('#selected-rotator-controls .rotator-dot'));
        const counter = document.getElementById('selected-rotator-counter');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let idx = 0;
        let timer = null;

        const go = (next) => {
          if (next === idx) return;
          items[idx].classList.remove('is-visible');
          items[idx].setAttribute('aria-hidden', 'true');
          idx = (next + items.length) % items.length;
          items[idx].classList.add('is-visible');
          items[idx].setAttribute('aria-hidden', 'false');
          dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
          if (counter) counter.textContent = `${String(idx + 1).padStart(2, '0')} / ${String(items.length).padStart(2, '0')}`;
        };

        const start = () => {
          if (reduced) return;
          stop();
          timer = setInterval(() => go(idx + 1), intervalMs);
        };
        const stop = () => { if (timer) { clearInterval(timer); timer = null; } };

        rotator.addEventListener('mouseenter', stop);
        rotator.addEventListener('mouseleave', start);
        rotator.addEventListener('focusin', stop);
        rotator.addEventListener('focusout', start);
        dots.forEach((dot, i) => {
          dot.addEventListener('click', () => { go(i); start(); });
        });

        start();
      })();
    </script>
  </section>
</BaseLayout>
