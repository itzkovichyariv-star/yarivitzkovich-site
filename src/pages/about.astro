---
import BaseLayout from '../layouts/BaseLayout.astro';
import metrics from '../data/metrics.json';

const affiliations = [
  { org: 'Academy of Management (AOM)', period: '2018–present' },
  { org: 'International Association on Workplace Bullying and Harassment (IAWBH)', period: '2018–present' },
  { org: 'Co-manager, Bystanders & Organizational Influences SIG, IAWBH', period: '2018–2024' },
  { org: 'National task force to mitigate bullying and promote anti-bullying legislation', period: '2019–2024' },
  { org: 'Institute for Studying Antisemitism in Business and Economy (SABE), Associate Member', period: '2024' },
  { org: 'International Behavior in Organizations Research Group (BORG)', period: '2021–present' },
];

const students = [
  { name: 'Ela Barhon', topic: 'Constructing and validating a new model for bystanders facing mistreatment', degree: 'PhD', status: 'In progress' },
  { name: 'Liron Asraf', topic: 'Incivilities in organizations and their consequences: aggressors, victims, colleagues and their interconnections', degree: 'PhD', status: 'Completed Dec 2024' },
];
---
<BaseLayout title="About — Yariv Itzkovich" description="About Yariv Itzkovich — researcher of workplace mistreatment and AI in organizations.">
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-40 pb-32">

    <!-- Header -->
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">About</div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <h1 class="font-display text-5xl md:text-6xl mb-10" style="font-weight: 300">About.</h1>
        <p class="text-lg leading-relaxed max-w-2xl" style="color: var(--text)">
          Yariv Itzkovich is a researcher of workplace mistreatment (incivility, bullying, and abusive behavior in organizations) and of the potential for AI-based systems to detect and mitigate such behavior in real time. He completed his PhD at Ben Gurion University (2010) and was a Visiting Scholar at the University of Central Florida (2023–2024). He is Associate Editor at the <em>Journal of Managerial Psychology</em> and Head of the Human Resource Management track, Department of Sociology and Anthropology, at Ariel University.
        </p>
      </div>
    </div>

    <div class="h-px mb-20" style="background-color: var(--divider)"></div>

    <!-- Citation metrics -->
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">Impact</div>
      </div>
      <div class="col-span-12 md:col-span-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-6">
          <div>
            <div class="font-display text-5xl mb-1" style="font-weight: 300">{metrics.googleScholar.hIndex}</div>
            <div class="font-mono text-xs uppercase tracking-widest text-soft">H-index</div>
            <div class="font-mono text-xs text-muted mt-1">Google Scholar</div>
          </div>
          <div>
            <div class="font-display text-5xl mb-1" style="font-weight: 300">{metrics.googleScholar.citations}</div>
            <div class="font-mono text-xs uppercase tracking-widest text-soft">Citations</div>
            <div class="font-mono text-xs text-muted mt-1">Google Scholar</div>
          </div>
          <div>
            <div class="font-display text-5xl mb-1" style="font-weight: 300">{metrics.openAlex.hIndex}</div>
            <div class="font-mono text-xs uppercase tracking-widest text-soft">H-index</div>
            <div class="font-mono text-xs text-muted mt-1">OpenAlex</div>
          </div>
          <div>
            <div class="font-display text-5xl mb-1" style="font-weight: 300">{metrics.openAlex.citations}</div>
            <div class="font-mono text-xs uppercase tracking-widest text-soft">Citations</div>
            <div class="font-mono text-xs text-muted mt-1">OpenAlex · auto-updated</div>
          </div>
        </div>
        <p class="font-mono text-xs text-soft">OpenAlex metrics refresh every Monday. Google Scholar figures are updated manually.</p>
      </div>
    </div>

    <div class="h-px mb-20" style="background-color: var(--divider)"></div>

    <!-- Affiliations -->
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">Affiliations</div>
      </div>
      <div class="col-span-12 md:col-span-10 space-y-0">
        {affiliations.map((a) => (
          <div class="grid grid-cols-12 gap-4 py-5 border-t" style="border-color: var(--divider)">
            <div class="col-span-12 md:col-span-9 text-base">{a.org}</div>
            <div class="col-span-12 md:col-span-3 md:text-right font-mono text-xs text-muted">{a.period}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="h-px mb-20" style="background-color: var(--divider)"></div>

    <!-- Doctoral students -->
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-2">
        <div class="font-mono text-xs uppercase tracking-widest text-soft">Doctoral<br/>students</div>
      </div>
      <div class="col-span-12 md:col-span-10 space-y-0">
        {students.map((s) => (
          <div class="grid grid-cols-12 gap-4 py-8 border-t" style="border-color: var(--divider)">
            <div class="col-span-12 md:col-span-9">
              <p class="font-display text-xl mb-1" style="font-weight: 400">{s.name}</p>
              <p class="text-muted text-sm max-w-xl">{s.topic}</p>
            </div>
            <div class="col-span-12 md:col-span-3 md:text-right">
              <span class="font-mono text-xs uppercase tracking-widest text-soft block">{s.degree}</span>
              <span class="font-mono text-xs text-muted">{s.status}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

  </section>
</BaseLayout>
