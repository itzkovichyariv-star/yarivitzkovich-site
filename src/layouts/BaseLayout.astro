---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'he';
  langHref?: string;
}

const {
  title,
  description = 'Yariv Itzkovich — research on how mistreatment spills over in organizations, bystander intervention, and AI-based mitigation.',
  lang = 'en',
  langHref,
} = Astro.props;

const dir = lang === 'he' ? 'rtl' : 'ltr';
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Default is light ("newspaper") mode. Dark is opt-in via the toggle.
      (() => {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <Nav lang={lang} langHref={langHref} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
