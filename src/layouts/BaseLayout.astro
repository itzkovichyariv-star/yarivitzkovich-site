---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'he';
  langHref?: string;
  /** Override the default Person JSON-LD (e.g. ScholarlyArticle on paper pages) */
  suppressPersonSchema?: boolean;
  /** When the page is a paper detail, set these so visit tracking attributes the visit to that paper. */
  paperSlug?: string;
  paperTitle?: string;
}

const {
  title,
  description = 'Yariv Itzkovich — research on how mistreatment spills over in organizations, bystander intervention, and AI-based mitigation.',
  lang = 'en',
  langHref,
  suppressPersonSchema = false,
  paperSlug,
  paperTitle,
} = Astro.props;

const dir = lang === 'he' ? 'rtl' : 'ltr';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://yarivitzkovich.org').href;
const ogImage = new URL('/images/signature-banner.png', Astro.site ?? 'https://yarivitzkovich.org').href;
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Yariv Itzkovich" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/he\//, '/'), Astro.site ?? 'https://yarivitzkovich.org').href} />
    <link rel="alternate" hreflang="he" href={new URL(Astro.url.pathname.startsWith('/he') ? Astro.url.pathname : `/he${Astro.url.pathname}`, Astro.site ?? 'https://yarivitzkovich.org').href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site ?? 'https://yarivitzkovich.org').href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Paper context for live-globe tracking (only on paper detail pages) */}
    {paperSlug && <meta name="paper-slug" content={paperSlug} />}
    {paperTitle && <meta name="paper-title" content={paperTitle} />}

    <!-- Open Graph / social previews -->
    <meta property="og:site_name" content="Yariv Itzkovich" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'he' ? 'he_IL' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'he' ? 'en_US' : 'he_IL'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      // Auto is the default and the master: dark 19:00–06:59, light otherwise.
      // Manual toggle overrides auto only until the next auto-transition (07:00 or 19:00),
      // so the next morning/evening auto silently takes back over.
      (() => {
        function autoMode() {
          var h = new Date().getHours();
          return (h < 7 || h >= 19) ? 'dark' : 'light';
        }
        function nextTransition(from) {
          var d = new Date(from);
          var h = d.getHours();
          if (h < 7) {
            d.setHours(7, 0, 0, 0);
          } else if (h < 19) {
            d.setHours(19, 0, 0, 0);
          } else {
            d.setDate(d.getDate() + 1);
            d.setHours(7, 0, 0, 0);
          }
          return d;
        }
        function getOverride() {
          var raw = localStorage.getItem('theme-override');
          if (!raw) return null;
          try {
            var parsed = JSON.parse(raw);
            if (new Date() >= new Date(parsed.expiresAt)) {
              localStorage.removeItem('theme-override');
              return null;
            }
            return parsed.mode;
          } catch (e) {
            localStorage.removeItem('theme-override');
            return null;
          }
        }
        function setOverride(mode) {
          var expires = nextTransition(new Date()).toISOString();
          localStorage.setItem('theme-override', JSON.stringify({ mode: mode, expiresAt: expires }));
        }
        function apply() {
          var override = getOverride();
          var auto = autoMode();
          var effective = override || auto;
          if (effective === 'dark') document.documentElement.classList.add('dark');
          else document.documentElement.classList.remove('dark');
          document.documentElement.dataset.themeEffective = effective;
          document.documentElement.dataset.themeOverridden = override ? 'yes' : 'no';
        }
        apply();
        window.__applyTheme = apply;
        window.__setThemeOverride = setOverride;
        // Re-check every minute: catches the 07:00 / 19:00 flip and expires stale overrides.
        setInterval(apply, 60000);
      })();
    </script>

    {!suppressPersonSchema && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        '@id': 'https://yarivitzkovich.org/#person',
        name: 'Yariv Itzkovich',
        alternateName: [
          'Yariv Itzkovich, PhD',
          'Y. Itzkovich',
          'Yariv Iztkovich',
          'יריב איצקוביץ',
          'ד״ר יריב איצקוביץ',
        ],
        givenName: 'Yariv',
        familyName: 'Itzkovich',
        honorificSuffix: 'PhD',
        jobTitle: [
          'Associate Editor, Journal of Managerial Psychology',
          'Senior Lecturer, Ariel University',
          'Head of the Human Resource Management Track',
        ],
        description: 'Researcher of workplace mistreatment, bystander intervention, and AI-based mitigation. Associate Editor at the Journal of Managerial Psychology.',
        url: 'https://yarivitzkovich.org',
        image: 'https://yarivitzkovich.org/images/headshot.jpg',
        email: 'mailto:Yarivi@ariel.ac.il',
        worksFor: {
          '@type': 'CollegeOrUniversity',
          name: 'Ariel University',
          url: 'https://www.ariel.ac.il',
          department: {
            '@type': 'EducationalOrganization',
            name: 'Department of Sociology and Anthropology — HRM & Organizational Development Track',
          },
        },
        affiliation: [
          {
            '@type': 'Organization',
            name: 'Journal of Managerial Psychology',
            url: 'https://www.emerald.com/insight/publication/issn/0268-3946',
          },
          {
            '@type': 'Organization',
            name: 'International Association on Workplace Bullying and Harassment (IAWBH)',
          },
        ],
        knowsAbout: [
          'Workplace incivility',
          'Workplace bullying',
          'Bystander intervention',
          'Abusive supervision',
          'Organizational behaviour',
          'AI and human-AI collaboration',
          'Organizational consulting',
        ],
        identifier: [
          { '@type': 'PropertyValue', propertyID: 'ORCID', value: '0000-0002-3296-6518' },
        ],
        sameAs: [
          'https://orcid.org/0000-0002-3296-6518',
          'https://scholar.google.com/citations?user=HyN_EIgAAAAJ',
        ],
      })} />
    )}

    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        '@id': 'https://yarivitzkovich.org/#website',
        name: 'Yariv Itzkovich',
        alternateName: ['Yariv Itzkovich — Research on workplace mistreatment and AI', 'יריב איצקוביץ'],
        url: 'https://yarivitzkovich.org',
        description: 'The personal site and research archive of Yariv Itzkovich, PhD — Associate Editor at the Journal of Managerial Psychology.',
        inLanguage: ['en', 'he'],
        about: { '@id': 'https://yarivitzkovich.org/#person' },
        author: { '@id': 'https://yarivitzkovich.org/#person' },
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://yarivitzkovich.org/publications?search={query}',
          'query-input': 'required name=query',
        },
      })} />
    )}
  </head>
  <body>
    <Nav lang={lang} langHref={langHref} />
    <SearchOverlay />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <script is:inline>
      // Live globe — visit tracking (P0).
      // Classifies the visitor as first_time or returning based on a flag
      // in localStorage, then POSTs the event to /api/track-visit.
      // No cookies, no third-party calls. Safe to remove later by deleting
      // this script block — backend will simply receive nothing from this page.
      (() => {
        try {
          if (navigator.webdriver) return; // skip headless browsers
          var STORAGE_KEY = 'yi_visitedBefore';
          var visited = localStorage.getItem(STORAGE_KEY);
          var visitor_class = visited ? 'returning' : 'first_time';
          if (!visited) {
            try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch (e) {}
          }

          var page_path = location.pathname || '/';

          // Optional paper context — if a paper detail page sets these meta tags,
          // we attach the slug + title to the event.
          var slugMeta = document.querySelector('meta[name="paper-slug"]');
          var titleMeta = document.querySelector('meta[name="paper-title"]');
          var paper_slug = slugMeta ? slugMeta.getAttribute('content') : null;
          var paper_title = titleMeta ? titleMeta.getAttribute('content') : null;

          var body = JSON.stringify({ visitor_class: visitor_class, page_path: page_path, paper_slug: paper_slug, paper_title: paper_title });

          // Use sendBeacon if available (won't block page transitions); fall back to fetch.
          if (navigator.sendBeacon) {
            var blob = new Blob([body], { type: 'application/json' });
            navigator.sendBeacon('/api/track-visit', blob);
          } else {
            fetch('/api/track-visit', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: body,
              keepalive: true,
            }).catch(function () {});
          }
        } catch (e) { /* fail silently — never break the page */ }
      })();
    </script>
  </body>
</html>
