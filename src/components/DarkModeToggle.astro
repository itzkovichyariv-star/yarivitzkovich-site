---
// Theme is always auto (time-based) by default.
// Clicking the toggle flips today's theme but auto silently resumes at the
// next transition (07:00 or 19:00), so every new day starts in auto.
---
<button
  id="theme-toggle"
  type="button"
  class="border border-current rounded-full w-8 h-8 flex items-center justify-center hover:opacity-70 transition-opacity"
  aria-label="Toggle theme for today"
  title="Theme flips automatically at 07:00 and 19:00. Click to override for today."
>
  <!-- Sun icon (shown when effective theme is light) -->
  <svg class="dark:hidden w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <!-- Moon icon (shown when effective theme is dark) -->
  <svg class="hidden dark:block w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>
<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.themeEffective || 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      if (typeof window.__setThemeOverride === 'function') window.__setThemeOverride(next);
      if (typeof window.__applyTheme === 'function') window.__applyTheme();
    });
  })();
</script>
