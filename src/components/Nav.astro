---
import DarkModeToggle from './DarkModeToggle.astro';
import LangToggle from './LangToggle.astro';
import { site } from '../data/site';

interface Props {
  lang?: 'en' | 'he';
  langHref?: string; // override for the lang toggle destination
}
const { lang = 'en', langHref } = Astro.props;

const labels = {
  en: { home: 'Home', work: 'Publications', now: 'Currently', teaching: 'Teaching', contact: 'Contact' },
  he: { home: 'ראשי', work: 'פרסומים', now: 'כעת', teaching: 'הוראה', contact: 'יצירת קשר' },
};
const t = labels[lang];
const homeHref = lang === 'en' ? '/' : '/he/';
const en = (path: string) => `/${path}`;
---
<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-divider"
  style="background-color: var(--nav-bg)"
>
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-5 flex items-center justify-between text-xs font-mono uppercase tracking-widest">
    <a href={homeHref} class="hover:opacity-60 transition-opacity">
      {site.shortName} / Est. {site.establishedYear}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex gap-8">
      <a href={homeHref} class="hover:opacity-60 transition-opacity">{t.home}</a>
      <a href={en('publications')} class="hover:opacity-60 transition-opacity">{t.work}</a>
      <a href={`${homeHref}#now`} class="hover:opacity-60 transition-opacity">{t.now}</a>
      <a href={en('teaching')} class="hover:opacity-60 transition-opacity">{t.teaching}</a>
      <a href="#contact" class="hover:opacity-60 transition-opacity">{t.contact}</a>
    </nav>

    <div class="flex items-center gap-4">
      <!-- Search — always visible -->
      <button
        id="nav-search-btn"
        type="button"
        class="flex items-center gap-1.5 hover:opacity-60 transition-opacity"
        aria-label="Search publications"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <span class="hidden sm:inline">Search</span>
      </button>
      <script is:inline>
        document.getElementById('nav-search-btn')?.addEventListener('click', function() {
          var input = document.getElementById('pub-search');
          if (input) {
            input.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(function() { input.focus(); }, 150);
          } else {
            window.location.href = '/publications?focus=search';
          }
        });
      </script>
      <DarkModeToggle />
      <LangToggle lang={lang} href={langHref} />
      <!-- Hamburger — mobile only -->
      <button id="nav-menu-btn" class="md:hidden flex flex-col gap-1.5" aria-label="Open menu" aria-expanded="false">
        <span class="block w-5 h-px bg-current transition-all"></span>
        <span class="block w-5 h-px bg-current transition-all"></span>
        <span class="block w-3.5 h-px bg-current transition-all"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="nav-mobile-menu"
    class="hidden md:hidden border-t"
    style="background-color: var(--nav-bg); border-color: var(--divider)"
  >
    <nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5 font-mono text-xs uppercase tracking-widest">
      <a href={homeHref} class="hover:opacity-60 transition-opacity">{t.home}</a>
      <a href={en('publications')} class="hover:opacity-60 transition-opacity">{t.work}</a>
      <a href={`${homeHref}#now`} class="hover:opacity-60 transition-opacity">{t.now}</a>
      <a href={en('teaching')} class="hover:opacity-60 transition-opacity">{t.teaching}</a>
      <a href="#contact" class="hover:opacity-60 transition-opacity">{t.contact}</a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById('nav-menu-btn');
    const menu = document.getElementById('nav-mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', () => {
      const open = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', open);
      btn.setAttribute('aria-expanded', String(!open));
    });
    // Close on nav link click
    menu.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
