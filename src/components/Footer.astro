---
import { site } from '../data/site';

interface Props {
  lang?: 'en' | 'he';
}
const { lang = 'en' } = Astro.props;

const profileLinks: Array<{ label: string; href: string }> = [
  { label: 'Google Scholar', href: site.profiles.googleScholar },
  { label: 'ORCID', href: site.profiles.orcid },
  { label: 'ResearchGate', href: site.profiles.researchGate },
  { label: 'LinkedIn', href: site.profiles.linkedin },
  { label: 'GitHub (templates)', href: site.profiles.github },
  { label: 'Mastodon', href: site.profiles.mastodon },
  { label: 'Bluesky', href: site.profiles.bluesky },
].filter((link) => Boolean(link.href));

const showProfiles = site.display.footerProfiles && profileLinks.length > 0;
const showCv = site.display.findCv;

const copy = {
  en: {
    kicker: '',
    heading: 'Get in touch.',
    lede: 'For collaborations, editorial matters at JMP, speaking, prospective PhD students, or master students with an interest in technology and the dark side of organizations.',
    email: 'Email',
    cv: 'Download CV',
    findMe: 'Find me',
    tagline: '',
    copy: `© ${site.shortName} · ${new Date().getFullYear()}`,
  },
  he: {
    kicker: '',
    heading: 'צרו קשר.',
    lede: 'לשיתופי פעולה, ענייני עריכה ב-JMP, הרצאות, סטודנטים המעוניינים בלימודי דוקטורט, או תלמידי מחקר בתואר שני עם עניין בטכנולוגיה וצד האפל של ארגונים.',
    email: 'אימייל',
    cv: 'קורות חיים',
    findMe: 'מצאו אותי',
    tagline: '',
    copy: `© ${site.shortName} · ${new Date().getFullYear()}`,
  },
}[lang];
---
<footer id="contact" class="bg-accent" style="background-color: var(--color-accent); color: var(--color-bg)">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-24">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-8">
        <div class="font-mono text-xs uppercase tracking-widest opacity-80 mb-6">
          Associate Editor · <span style="font-style: italic; text-transform: none; letter-spacing: normal">Journal of Managerial Psychology</span>
        </div>
        {copy.kicker && <div class="font-mono text-xs uppercase tracking-widest opacity-60 mb-4">{copy.kicker}</div>}
        <h2 class="font-display font-light leading-none" style="font-size: clamp(2.5rem, 7vw, 5rem); font-weight: 300">
          {copy.heading}
        </h2>
        <p class="mt-6 max-w-md opacity-80">{copy.lede}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm border border-current hover:opacity-80 transition-opacity"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-10 5L2 7"/>
            </svg>
            {copy.email}
          </a>
          {showCv && (
            <a
              href="/pdfs/yariv-cv-full.pdf"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm border border-current hover:opacity-80 transition-opacity"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              {copy.cv}
            </a>
          )}
        </div>
      </div>
    </div>
    <div class="mt-20 pt-6 border-t border-current border-opacity-20 flex items-center justify-between flex-wrap gap-4">
      <div class="font-mono text-xs uppercase tracking-widest opacity-60">{copy.copy}</div>
      <div class="flex items-center gap-3">
        {site.profiles.googleScholar && (
          <a
            href={site.profiles.googleScholar}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest opacity-70 hover:opacity-100 transition-opacity"
            aria-label="Google Scholar profile"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M5.242 13.769 0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269z"/>
              <path d="M12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
            </svg>
            Scholar
          </a>
        )}
        {site.profiles.orcid && (
          <a
            href={site.profiles.orcid}
            target="_blank"
            rel="noopener noreferrer me"
            class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-widest opacity-70 hover:opacity-100 transition-opacity"
            aria-label="ORCID profile"
          >
            <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
              <path d="M128 0C57.3 0 0 57.3 0 128s57.3 128 128 128 128-57.3 128-128S198.7 0 128 0zm-23.9 57.2c5.2 0 9.4 4.2 9.4 9.4s-4.2 9.4-9.4 9.4-9.4-4.2-9.4-9.4 4.2-9.4 9.4-9.4zm-13 34.9h26.1v92.7H91.1V92.1zm45.7 0h34.2c32.6 0 45.9 23.4 45.9 46.3 0 25.2-17.3 46.3-45.9 46.3h-34.2V92.1zm26.1 20.5v51.7h7.4c18.3 0 21.5-15.5 21.5-25.9 0-11.7-4.4-25.9-21.5-25.9h-7.4z"/>
            </svg>
            ORCID
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
