---
import { site } from '../data/site';

interface Props {
  lang?: 'en' | 'he';
}
const { lang = 'en' } = Astro.props;

const profileLinks: Array<{ label: string; href: string }> = [
  { label: 'Google Scholar', href: site.profiles.googleScholar },
  { label: 'ORCID', href: site.profiles.orcid },
  { label: 'ResearchGate', href: site.profiles.researchGate },
  { label: 'LinkedIn', href: site.profiles.linkedin },
  { label: 'GitHub (templates)', href: site.profiles.github },
  { label: 'Mastodon', href: site.profiles.mastodon },
  { label: 'Bluesky', href: site.profiles.bluesky },
].filter((link) => Boolean(link.href));

const showProfiles = site.display.footerProfiles && profileLinks.length > 0;
const showCv = site.display.findCv;

const copy = {
  en: {
    kicker: '',
    heading: 'Get in touch.',
    lede: 'For collaborations, editorial matters at JMP, speaking, prospective PhD students, or master students with an interest in technology and the dark side of organizations.',
    emailLabel: site.email,
    cv: 'Download CV',
    findMe: 'Find me',
    tagline: '',
    copy: `© ${site.shortName} · ${new Date().getFullYear()}`,
  },
  he: {
    kicker: '',
    heading: 'צרו קשר.',
    lede: 'לשיתופי פעולה, ענייני עריכה ב-JMP, הרצאות, סטודנטים המעוניינים בלימודי דוקטורט, או תלמידי מחקר בתואר שני עם עניין בטכנולוגיה וצד האפל של ארגונים.',
    emailLabel: site.email,
    cv: 'קורות חיים',
    findMe: 'מצאו אותי',
    tagline: '',
    copy: `© ${site.shortName} · ${new Date().getFullYear()}`,
  },
}[lang];
---
<footer id="contact" class="bg-accent" style="background-color: var(--color-accent); color: var(--color-bg)">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-24">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-8">
        {copy.kicker && <div class="font-mono text-xs uppercase tracking-widest opacity-60 mb-4">{copy.kicker}</div>}
        <h2 class="font-display font-light leading-none" style="font-size: clamp(2.5rem, 7vw, 5rem); font-weight: 300">
          {copy.heading}
        </h2>
        <p class="mt-6 max-w-md opacity-80">{copy.lede}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm transition-opacity hover:opacity-80"
            style="background-color: var(--color-bg); color: var(--color-ink)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-10 5L2 7"/>
            </svg>
            {copy.emailLabel}
          </a>
          {showCv && (
            <a
              href="/pdfs/yariv-cv-full.pdf"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm border border-current hover:opacity-80 transition-opacity"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              {copy.cv}
            </a>
          )}
        </div>
      </div>
      {showProfiles && (
        <div class="col-span-12 md:col-span-4 md:text-right">
          <div class="font-mono text-xs uppercase tracking-widest opacity-60 mb-4">{copy.findMe}</div>
          <div class="space-y-2 text-sm">
            {profileLinks.map((link) => (
              <div>
                <a href={link.href} class="hover:underline" rel="me noopener" target="_blank">
                  {link.label} ↗
                </a>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
    <div class="mt-20 pt-6 border-t border-current border-opacity-20 flex justify-between text-xs font-mono uppercase tracking-widest opacity-60 flex-wrap gap-2">
      <div>{copy.copy}</div>
      <div>{copy.tagline}</div>
    </div>
  </div>
</footer>
